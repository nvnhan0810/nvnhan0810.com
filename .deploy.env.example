## Copy to .deploy.env (do not commit) and edit.
## Then run: ./scripts/deploy.sh

# Required
DEPLOY_HOST="your.vps.host"
DEPLOY_USER="deploy"
DEPLOY_PATH="/var/www/nvnhan0810.com"

# Optional
# DEPLOY_PORT="22"
# DEPLOY_SSH_KEY="$HOME/.ssh/id_ed25519"

# Optional remote commands to run after upload (executed on VPS in DEPLOY_PATH)
# Examples:
# DEPLOY_POST_COMMANDS="php artisan optimize:clear && php artisan optimize"
# DEPLOY_POST_COMMANDS="php artisan migrate --force"

